# Date de generation : {{ date_generation }}
# Options : screenshots={{ with_screenshots }}, timeout={{ timeout_ms }}ms

import re
import asyncio
from pathlib import Path
from playwright.async_api import async_playwright, expect, Page, Frame


# ── Screenshot helper ──────────────────────────────────────────────────────
SCREENSHOTS_DIR = Path("screenshots/{{ test_function_name }}")

async def _screenshot(page: Page, step_num: int, label: str) -> None:
    """Capture une capture d'écran après chaque step (si activé)."""
    SCREENSHOTS_DIR.mkdir(parents=True, exist_ok=True)
    safe_label = re.sub(r"[^\w\-]", "_", label)[:60]
    path = SCREENSHOTS_DIR / f"step_{step_num:02d}_{safe_label}.png"
    await page.screenshot(path=str(path), full_page=False)


# ── Context helpers ────────────────────────────────────────────────────────
async def _get_frame(page: Page, frame_name: str) -> Frame:
    """Retourne une iframe par nom/id (avec attente implicite)."""
    await page.wait_for_selector(f"iframe[name='{frame_name}'], iframe#{frame_name}", timeout={{ timeout_ms }})
    frame = page.frame(name=frame_name) or page.frame(url=re.compile(frame_name))
    if frame is None:
        raise RuntimeError(f"iframe '{frame_name}' introuvable")
    return frame


async def _accept_dialog(page: Page) -> None:
    """Accepte le premier dialog (alert/confirm/prompt) qui apparaît."""
    page.once("dialog", lambda d: asyncio.ensure_future(d.accept()))


async def _dismiss_dialog(page: Page) -> None:
    """Refuse le premier dialog qui apparaît."""
    page.once("dialog", lambda d: asyncio.ensure_future(d.dismiss()))


