# Application
APP_NAME=IA Test Agent
DEBUG=true
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:4200","http://localhost:5288"]

# Backend .NET API URL (used to receive callbacks and resolve scenario data)
BACKEND_URL=http://localhost:5288

# Base de donnees
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ia_test_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Modeles IA
NLP_MODEL_PATH=trained_models/nlp
YOLO_MODEL_PATH=trained_models/vision/yolov8_ui_elements.pt

# Playwright
HEADLESS=true
BROWSER_TYPE=chromium
# Slow motion entre chaque action (ms). 0=rapide, 800=confortable pour observer
SLOW_MO_MS=0

# Chemins
SCREENSHOTS_DIR=reports/screenshots
REPORTS_DIR=reports/html
GENERATED_TESTS_DIR=reports/generated_tests
