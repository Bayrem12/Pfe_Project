# AutoTestify – Environment Variables
# Copy this file to .env and fill in the required values.
# NEVER commit .env to git (it's in .gitignore).

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=TestAutomation_Db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── JWT (min 32 chars, keep secret) ───────────────────────────────────────
# Generate one: openssl rand -base64 48
JWT_KEY=CHANGE_ME_at_least_32_characters_long_secret_key!!

# ── Email (optional, leave blank to disable) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# ── OAuth (optional) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=
